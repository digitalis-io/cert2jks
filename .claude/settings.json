{
  "permissions": {
    "allow": [
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(go fmt:*)",
      "Bash(gofmt:*)",
      "Bash(goimports:*)",
      "Bash(go mod:*)",
      "Bash(go run:*)",
      "Bash(go doc:*)",
      "Bash(go version)",
      "Bash(go env:*)",
      "Bash(go tool:*)",
      "Bash(golangci-lint:*)",
      "Bash(make build)",
      "Bash(make test)",
      "Bash(make test-race)",
      "Bash(make lint)",
      "Bash(make fmt)",
      "Bash(make vet)",
      "Bash(make tidy)",
      "Bash(make cover)",
      "Bash(make bench)",
      "Bash(make help)",
      "Bash(pre-commit run:*)",
      "Bash(pre-commit install:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(go clean -modcache)"
    ],
    "ask": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); cmd=$(echo \"$input\" | python3 -c \"import json,sys; d=json.load(sys.stdin); print(d.get('command',''))\" 2>/dev/null || echo \"\"); if echo \"$cmd\" | grep -qE '^git commit'; then cd \"$(git rev-parse --show-toplevel)\" && pre-commit run --files $(git diff --cached --name-only | tr '\\n' ' ') 2>&1 || true; fi"
          }
        ]
      }
    ]
  }
}
